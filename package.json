{
  "name": "forge-aws-demo",
  "version": "0.0.0",
  "private": true,
  "description": "Example Forge app using native Node.js runtime and AWS SDK for JavaScript",
  "homepage": "https://github.com/ibuchanan/forge-aws-sdk-hello-world",
  "repository": {
    "type": "git",
    "url": "https://github.com/ibuchanan/forge-aws-sdk-hello-world"
  },
  "license": "Apache-2.0",
  "contributors": [
    "Ian Buchanan <ibuchanan@atlassian.com>"
  ],
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "npm -s run clean && npm -s run build:typescript",
    "build:typescript": "tsc",
    "check": "npm -s run lint:typescript && npm -s run lint:dotenv && npm -s run lint:biome && npm -s run format:check && npm -s run lint:forge",
    "clean": "rm -rf ./dist",
    "deploy": "npm -s run forge:variables:set:dotenv && npm -s run forge:deploy",
    "deprovision": "set -a && . ./.env && ./scripts/webtrigger-deprovision.sh",
    "deprovision:webtrigger": "set -a && . ./.env && forge webtrigger --functionKey 'webtrigger-deprovision' $(forge install list --json | node -e 'console.log(JSON.parse(fs.readFileSync(0)).filter(i=>\"'$FORGE_DEV_SITE'\".includes(i.site))[0].id)') | awk 'NR == 9 {print}'",
    "first-time": "npm -s run first-time:dotenv && npm -s run first-time:register",
    "first-time:dotenv": "cp --update ./.env.example ./.env",
    "first-time:register": "npm -s run forge:register",
    "forge:deploy": "set -a && . ./.env && forge deploy",
    "forge:environments": "set -a && . ./.env && forge environments",
    "forge:feedback": "set -a && . ./.env && forge feedback",
    "forge:install": "set -a && . ./.env && forge install --product Jira --site $FORGE_DEV_SITE",
    "forge:install:upgrade": "set -a && . ./.env && forge install --upgrade --site $FORGE_DEV_SITE",
    "forge:install-list": "set -a && . ./.env && forge install list",
    "forge:login": "set -a && . ./.env && forge login",
    "forge:logout": "set -a && . ./.env && forge logout",
    "forge:logs": "set -a && . ./.env && forge logs",
    "forge:providers": "set -a && . ./.env && forge providers",
    "forge:register": "set -a && . ./.env && forge register",
    "forge:settings": "set -a && . ./.env && forge settings",
    "forge:storage": "set -a && . ./.env && forge storage",
    "forge:tunnel": "set -a && . ./.env && forge tunnel",
    "forge:uninstall": "set -a && . ./.env && forge uninstall",
    "forge:variables:list": "set -a && . ./.env && forge variables list",
    "forge:variables:set": "set -a && . ./.env && forge variables set",
    "forge:variables:set:dotenv": "./scripts/forge-vars-from-env.sh",
    "forge:variables:set-encrypted": "set -a && . ./.env && forge variables set --encrypt",
    "forge:variables:unset": "set -a && . ./.env && forge variables unset",
    "forge:webtrigger": "set -a && . ./.env && forge webtrigger",
    "forge:whoami": "set -a && . ./.env && forge whoami",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "lint": "npm -s run lint:typescript && npm -s run lint:dotenv && npm -s run lint:biome && npm -s run format:check && npm -s run lint:forge",
    "lint:biome": "biome lint .",
    "lint:dotenv": "./scripts/check-env.js",
    "lint:fix": "npm -s run lint:typescript && npm -s run lint:dotenv && npm -s run lint:fix:biome && npm -s run format && npm -s run lint:fix:forge",
    "lint:fix:biome": "biome lint --write .",
    "lint:fix:forge": "npm -s run lint:forge -- --fix",
    "lint:forge": "set -a && . ./.env && forge lint",
    "lint:forge:lint:verbose": "forge lint --verbose",
    "lint:typescript": "npm -s run build:typescript -- --noEmit",
    "provision": "set -a && . ./.env && ./scripts/webtrigger-provision.sh",
    "provision:clientid": "set -a && . ./.env && curl --silent $FORGE_DEV_SITE/_edge/tenant_info",
    "provision:webtrigger": "set -a && . ./.env && forge webtrigger --functionKey 'webtrigger-provision' $(forge install list --json | node -e 'console.log(JSON.parse(fs.readFileSync(0)).filter(i=>\"'$FORGE_DEV_SITE'\".includes(i.site))[0].id)') | awk 'NR == 9 {print}'",
    "update": "npm -s run update:node",
    "update:node": "./scripts/set-node-version.sh"
  },
  "dependencies": {
    "@aws-sdk/client-dynamodb": "3",
    "@aws-sdk/client-s3": "3",
    "@aws-sdk/client-sns": "3",
    "@forge/api": "^7.2",
    "@forge/bridge": "^5.16.1",
    "@forge/react": "^11.16.0",
    "zod": "3"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.15",
    "@forge/cli": "*",
    "@types/node": "24",
    "dotenv-safe": "9",
    "typescript": "^5.9"
  },
  "engines": {
    "node": "24"
  }
}
